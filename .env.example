# ==============================
# AI-шопер — конфиг окружения
# Скопируй в .env и заполни
# ==============================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Прокси для РФ (опционально, напр. https://api.vsegpt.ru/v1)
ANTHROPIC_BASE_URL=

# --- База данных ---
# В продакшене хост — postgres (имя сервиса Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@postgres:5432/ai_shoper

# --- Redis ---
# В продакшене хост — redis (имя сервиса Docker Compose)
REDIS_URL=redis://redis:6379/0

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-...
# Произвольная строка для верификации webhook-запросов (генерируй: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=changeme
# URL твоего Mini App (настраивается в @BotFather → Edit Bot → Bot Menu Button)
TELEGRAM_MINI_APP_URL=https://your-domain.com
# Твой Telegram chat_id (для Wizard of Oz уведомлений, узнай через @userinfobot)
OWNER_CHAT_ID=0

# --- Маркетплейсы ---
# Ozon Partner API (https://seller.ozon.ru/app/settings/api-keys)
OZON_CLIENT_ID=
OZON_API_KEY=
# Wildberries CPA (Admitad: https://www.admitad.com)
WB_CPA_SUBID=
ADMITAD_API_KEY=
# Яндекс.Маркет Partner API OAuth (https://partner.market.yandex.ru)
YANDEX_MARKET_OAUTH=

# --- ЮKassa (https://yookassa.ru/my/shop-settings/api) ---
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# --- Sentry (https://sentry.io) ---
SENTRY_DSN=

# --- Misc ---
ENV=production
LOG_LEVEL=INFO
# Секрет для admin endpoint /api/v1/admin/setup-webhook (генерируй: openssl rand -hex 32)
SECRET_KEY=change-me-in-production
# Email для Let's Encrypt уведомлений (используется deploy.sh)
OWNER_EMAIL=your@email.com
